# ─────────────────────────────────────────────────────────────────────────────
#  OIC Gen3 — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── OIC Instance ──────────────────────────────────────────────────────────────
# Full OIC Gen3 base URL (include https://, no trailing slash)
# Found in OCI Console → Application Integration → Instances
OIC_HOST=https://design.integration.region.ocp.oraclecloud.com

# Service instance name (OIC About page → Service instance field)
INTEGRATION_INSTANCE=XXXX

# ── OAuth2 Client Credentials ─────────────────────────────────────────────────
# Create a Confidential Application in IDCS / OCI IAM and grant it the
# "ServiceAdministrator" or "ServiceDeveloper" role on the OIC instance.
OIC_CLIENT_ID=XXXX
OIC_CLIENT_SECRET=XXXX

# ── IDCS Token Endpoint ───────────────────────────────────────────────────────
# Format:  https://<idcs-stripe>.identity.oraclecloud.com/oauth2/v1/token
# Find your IDCS stripe in OCI Console → Identity → Domains (or classic IDCS URL)
OIC_TOKEN_URL=https://idcs-XXXX.identity.oraclecloud.com:443/oauth2/v1/token

# ── OAuth2 Scope (optional) ───────────────────────────────────────────────────
# Leave blank — OIC does not require a specific scope for client_credentials.
# Only set this if your IDCS app is configured with a custom allowed scope.
OIC_TOKEN_SCOPE=https://XXXX.integration.XXXXregion.ocp.oraclecloud.com:443urn:opc:resource:consumer::all

# ── Tuning (optional — defaults shown) ───────────────────────────────────────
# Number of records fetched per API page (max 100 for OIC)
# OIC_PAGE_SIZE=100

# HTTP request timeout in seconds
# OIC_TIMEOUT=60

# Number of retries on 5xx / 429 responses
# OIC_MAX_RETRIES=3
